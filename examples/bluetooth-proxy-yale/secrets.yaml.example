# Secrets template for Bluetooth Proxy

wifi_ssid: "YourWiFiNetwork"
wifi_password: "YourWiFiPassword"

# Fallback access point password (used when WiFi fails to connect)
ap_password: "fallback_ap_password"

# Home Assistant API encryption key (32 bytes, base64)
# Generate with: openssl rand -base64 32
api_key: "GENERATE_A_NEW_KEY_HERE"

# OTA update password
ota_password: "your_ota_password"
