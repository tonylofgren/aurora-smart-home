# Secrets template for Battery Temperature Sensor
# Copy to secrets.yaml and fill in your values

# WiFi credentials
wifi_ssid: "YourWiFiNetwork"
wifi_password: "YourWiFiPassword"

# Fallback AP password (used if WiFi is unreachable)
ap_password: "fallback_ap_password"

# Home Assistant API encryption key (32 bytes, base64)
api_encryption_key: "GENERATE_A_NEW_KEY_HERE"

# OTA update password
ota_password: "your_ota_password"
