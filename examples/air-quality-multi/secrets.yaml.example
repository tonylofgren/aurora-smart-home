# Generated by aurora@aurora-smart-home (esphome skill)
# https://github.com/tonylofgren/aurora-smart-home
#
# Copy this file to `secrets.yaml` in the same directory and fill in your
# values. The real `secrets.yaml` must NEVER be committed to git.
#
# Generate the api_key and ota_password with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Or in the ESPHome dashboard the api_key is auto-generated on first build.

# Wi-Fi credentials for the home network the device joins.
wifi_ssid: "your_wifi_ssid"
wifi_password: "your_wifi_password"

# Fallback access point password, used when the device cannot reach Wi-Fi.
# Connect to "air-quality hotspot" with this password to reconfigure.
ap_password: "fallback_ap_password"

# Home Assistant native API encryption key (base64, 32 bytes).
# Paste the same key into Home Assistant when adding the device.
api_key: "base64_encoded_32_byte_key_here"

# OTA update password. Required to push new firmware over the network.
ota_password: "your_ota_password"
