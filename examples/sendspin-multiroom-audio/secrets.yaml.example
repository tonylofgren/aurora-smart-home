# Secrets template for Sendspin multi-room audio
# Copy to secrets.yaml and fill in your values.

# WiFi credentials (same for hub and every speaker)
wifi_ssid: "YourWiFiNetwork"
wifi_password: "YourWiFiPassword"

# Static IP configuration for the HUB only
# Adjust to match your network. Use a reservation in your router/DHCP.
network_gateway: "192.168.1.1"
network_subnet: "255.255.255.0"
network_dns: "192.168.1.1"

# Fallback access point password (used when WiFi fails to connect)
ap_password: "fallback_ap_password"

# Home Assistant API encryption key (32 random bytes, base64)
# Generate with: openssl rand -base64 32
# Use the SAME key on hub and speakers if you want them to authenticate
# against the same HA instance.
api_key: "GENERATE_A_NEW_KEY_HERE"

# OTA update password
ota_password: "your_ota_password"
