# Generated by aurora@aurora-smart-home (esphome skill)
# https://github.com/tonylofgren/aurora-smart-home
#
# Copy this file to secrets.yaml and fill in your real values.
# secrets.yaml itself must NEVER be committed to git.

# WiFi credentials
wifi_ssid: "YourSSID"
wifi_password: "your-wifi-password"

# Static IP for the mailbox (recommended - speeds up wake-to-notify)
mailbox_static_ip: "192.168.1.50"
network_gateway: "192.168.1.1"
network_subnet: "255.255.255.0"
network_dns: "192.168.1.1"

# Fallback access point if WiFi credentials fail
fallback_ap_password: "change-me-please"

# ESPHome API encryption key
# Generate with: openssl rand -base64 32
api_encryption_key: "REPLACE_WITH_BASE64_32_BYTE_KEY"

# OTA update password
ota_password: "change-me-too"
