# Secrets template for the EV Charger Monitor example.
# Copy to secrets.yaml and fill in your values.
#
# TIP: generate secure keys with the helper scripts:
#   python scripts/generate_secrets.py --output
#   ./scripts/generate_secrets.sh --output

# WiFi credentials for the ESP32 to join your home network
wifi_ssid: "YourWiFiNetwork"
wifi_password: "YourWiFiPassword"

# Fallback access point password (used when WiFi fails to connect)
# The device exposes "ev-charger-monitor hotspot" with this password.
ap_password: "fallback_ap_password"

# Home Assistant API encryption key (32 random bytes, base64-encoded)
# Generate with: openssl rand -base64 32
api_key: "GENERATE_A_NEW_KEY_HERE"

# OTA update password (used by `esphome run` to push new firmware)
ota_password: "your_ota_password"

# OpenEVSE HTTP Basic auth (only needed if you set a password in the UI).
# The default install accepts user 'openevse' with no password.
# To pre-compute the Authorization header value, run:
#   printf 'openevse:yourpassword' | base64
# and paste the result into the basic_auth_header global in the YAML.
openevse_user: "openevse"
openevse_password: ""
