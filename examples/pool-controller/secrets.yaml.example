#
# Copy this file to secrets.yaml and fill in real values.
# Never commit secrets.yaml to git.

# WiFi credentials for the main network
wifi_ssid: "YourSSID"
wifi_password: "YourWifiPassword"

# Fallback access point password (used if WiFi cannot connect)
fallback_ap_password: "PoolFallback123"

# ESPHome API encryption key
# Generate one with: openssl rand -base64 32
api_encryption_key: "REPLACE_WITH_BASE64_32_BYTE_KEY"

# OTA update password
ota_password: "REPLACE_WITH_STRONG_PASSWORD"
