    "current_ma_active": 0.7,
    "current_sleep_ua": 0.1
  },
  "limitations": {
    "operating_temp_c": "-40 to +85",
    "pressure_range_hpa": "300-1100",
    "accuracy_temp_c": "+/- 1.0",
    "accuracy_pressure_hpa": "+/- 1",
    "no_humidity_sensor": true
  },
  "calibration": {
    "required": false,
    "type": null
  },
  "esphome": {
    "platform": "bmp280_i2c",
    "min_version": "2024.6.0"
  },
  "datasheet_url": "https://www.bosch-sensortec.com/products/environmental-sensors/pressure-sensors/bmp280/"
