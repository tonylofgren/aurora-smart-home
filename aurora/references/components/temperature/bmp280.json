{
  "$schema": "../../schemas/component-profile.schema.json",
  "schema_version": "1.0",
  "component_id": "bmp280",
  "display_name": "BMP280 Temperature & Pressure",
  "type": "temperature_pressure",
  "category": "environment",
  "protocol": "i2c",
  "last_verified": "2026-05-13",
  "variants": {
    "primary": "bmp280",
    "easily_confused_with": [
      {
        "component_id": "bme280",
        "difference": "BME280 (chip ID 0x60) adds humidity sensor; BMP280 (chip ID 0x58) has no humidity - boards look physically identical"
      }
    ],
    "knockoffs_known": true,
    "verification_method": "Read chip ID register: 0x58 = BMP280 (no humidity), 0x60 = BME280 (with humidity)"
  },
  "i2c": {
    "default_addresses": ["0x76", "0x77"],
    "address_strap_pin": "SDO (LOW=0x76, HIGH=0x77)",
    "max_speed_khz": 400
  },
  "pin_requirements": {
    "count": 2,
    "type": "i2c",
    "must_use_default_i2c_pins": false,
    "adc_required": false,
    "input_only_ok": false,
    "strapping_pin_ok": false,
    "5v_tolerant_required": false,
    "interrupt_capable_required": false
  },
  "external_components": {
    "pullup_resistor": {
      "value_ohm": 4700,
      "required": true,
      "note": "External I2C pull-ups if not provided by the breakout board"
    },
    "decoupling_cap": {
      "value_uf": 0.1,
      "required": true
    }
  },
  "power": {
    "voltage_min": 1.8,
    "voltage_max": 3.6,
    "tolerates_5v": false,
