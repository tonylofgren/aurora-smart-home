{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora-smart-home.dev/schemas/expander-profile.schema.json",
  "title": "Aurora GPIO Expander Profile",
  "type": "object",
  "required": [
    "schema_version", "expander_id", "display_name", "protocol",
    "channels", "channel_type"
  ],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"},
    "expander_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "display_name": {"type": "string", "minLength": 1},
    "protocol": {"enum": ["i2c", "spi"]},
    "channels": {"type": "integer", "minimum": 1},
    "channel_type": {"enum": ["digital_io", "pwm", "analog_input", "i2c_multiplex"]},
    "i2c": {
      "type": "object",
      "properties": {
        "default_addresses": {"type": "array", "items": {"type": "string"}},
        "address_pins": {"type": "array", "items": {"type": "string"}},
        "max_speed_khz": {"type": "integer"}
      }
    },
    "spi": {
      "type": "object",
      "properties": {
        "mode": {"type": "integer"},
        "max_clock_mhz": {"type": "number"}
      }
    },
    "limitations": {
      "type": "object",
      "properties": {
        "no_pwm": {"type": "boolean"},
        "open_drain_only": {"type": "boolean"},
        "max_current_per_pin_ma": {"type": "number"},
        "no_adc": {"type": "boolean"},
        "interrupt_pin_available": {"type": "boolean"}
      }
    },
    "use_cases": {"type": "array", "items": {"type": "string"}},
    "esphome": {
      "type": "object",
      "properties": {
        "platform": {"type": "string"},
        "min_version": {"type": "string"}
      }
    },
    "datasheet_url": {"type": "string", "format": "uri"},
    "last_verified": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "verified_source": {"type": "string"}
  }
}
