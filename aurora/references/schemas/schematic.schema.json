{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora-smart-home.dev/schemas/schematic.schema.json",
  "title": "Aurora Machine-Readable Schematic",
  "description": "Netlist-level companion to SCHEMATIC.md. Carries the same component list and net list in a form that scripts, BOM exporters, and EDA import helpers can consume. Human reasoning (design notes, block diagram) stays in SCHEMATIC.md.",
  "type": "object",
  "required": ["schema_version", "project", "components", "nets"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"},
    "project": {
      "type": "object",
      "required": ["name", "board", "generated"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "board": {"type": "string", "minLength": 1, "description": "Board or module id, e.g. esp32-c3-devkitm-1"},
        "revision": {"type": "string"},
        "generated": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "generated_with": {"type": "string"}
      },
      "additionalProperties": false
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["refdes", "value", "description"],
        "properties": {
          "refdes": {"type": "string", "pattern": "^[A-Z]+[0-9]+$", "description": "Reference designator, e.g. U1, R3, D2"},
          "value": {"type": "string", "minLength": 1, "description": "Part value or part name, e.g. ESP32-WROOM-32E, 10k, 100nF"},
          "description": {"type": "string", "minLength": 1},
          "package": {"type": "string", "description": "Footprint name, e.g. 0603, SOIC-8, module"},
          "lcsc": {"type": "string", "pattern": "^(C[0-9]+|TBD)$", "description": "LCSC part number for JLCPCB assembly, or TBD when sourcing is not yet decided"},
          "bom_row": {"type": "integer", "minimum": 1, "description": "Cross-reference to the row number in BOM.md"},
          "dnp": {"type": "boolean", "description": "Do not populate"}
        },
        "additionalProperties": false
      }
    },
    "nets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "pins"],
        "properties": {
          "name": {"type": "string", "minLength": 1, "description": "Net name, e.g. 3V3, GND, I2C_SDA"},
          "pins": {
            "type": "array",
            "minItems": 2,
            "items": {"type": "string", "pattern": "^[A-Z]+[0-9]+\\.[A-Za-z0-9_+\\-]+$", "description": "refdes.pin, e.g. U1.GPIO8"}
          },
          "note": {"type": "string", "description": "Per-net design note: pull-up value, impedance constraint, keep-out"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
